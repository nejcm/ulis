{
  "name": "@nejcm/ai-configs",
  "version": "1.0.0",
  "description": "AI configs",
  "license": "ISC",
  "author": "nejcm",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx src/index.ts",
    "build:opencode": "tsx src/index.ts --target opencode",
    "build:claude": "tsx src/index.ts --target claude",
    "build:codex": "tsx src/index.ts --target codex",
    "build:cursor": "tsx src/index.ts --target cursor",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf generated",
    "install:deps": "bun install",
    "install:configs": "bun install.js",
    "rebuild": "bun run build",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "dependencies": {
    "gray-matter": "~4.0.3",
    "zod": "~4.3.6"
  },
  "devDependencies": {
    "@types/node": "~24.12.2",
    "oxfmt": "~0.43.0",
    "rimraf": "~6.1.3",
    "tsx": "~4.21.0",
    "typescript": "~5.9.3"
  },
  "packageManager": "bun@1.3.10"
}
