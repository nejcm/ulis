{
  "$schema": "https://raw.githubusercontent.com/nejcm/ulis/main/schema/permissions.json",
  "claude": {
    "defaultMode": "default",
    "allow": [],
    "deny": [],
    "ask": []
  },
  "opencode": {
    "permission": {
      "read": "allow",
      "edit": "ask",
      "glob": "allow",
      "grep": "allow",
      "list": "allow",
      "bash": {
        "*": "ask",
        "bq query*": "allow",
        "bun run build:*": "allow",
        "bun run lint:file:*": "allow",
        "bun run test:*": "allow",
        "bun run test:file:*": "allow",
        "bun test:*": "allow",
        "cc:*": "allow",
        "comm:*": "allow",
        "find*": "allow"
      },
      "skill": {
        "*": "ask",
        "read-*": "allow",
        "search-*": "allow",
        "internal-*": "deny"
      },
      "webfetch": "allow",
      "websearch": "allow",
      "codesearch": "allow",
      "external_directory": "ask",
      "doom_loop": "ask"
    }
  },
  "codex": {
    "approvalMode": "suggest",
    "sandbox": "elevated"
  },
  "cursor": {
    "mcpAllowlist": [
      "*:*"
    ],
    "terminalAllowlist": [
      "git",
      "npm",
      "bun",
      "find",
      "ls"
    ]
  }
}